# ─────────────────────────────────────────────────────────────
# Trello MCP — วิธีขอ API Key และ Token
# ─────────────────────────────────────────────────────────────
# 1. ไปที่ https://trello.com/app-key  →  copy ค่า "API Key"
# 2. ในหน้าเดียวกัน กดลิงก์ "Generate a Token"  →  อนุญาตสิทธิ์  →  copy "Token"
# 3. copy ไฟล์นี้เป็น .env  แล้วใส่ค่าจริงด้านล่าง:
#       cp .env.example .env
#
# หมายเหตุ: .env ถูก ignore ใน git อยู่แล้ว ห้าม commit ค่า key จริง
# ─────────────────────────────────────────────────────────────

TRELLO_API_KEY=your_api_key_here
TRELLO_TOKEN=your_token_here
